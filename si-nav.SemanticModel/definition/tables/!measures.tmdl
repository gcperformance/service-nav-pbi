			    interactions_mag < 6, K_format,
			    interactions_mag < 9, M_format,
			    B_format
			)
			
			--result
			var result = if(total_vol = 0, "No volume", channels_with_max & " (" & format(max_vol, Mag_format) &"; "& format(max_vol_pc, "0%")&")")
			
			RETURN max_vol
		lineageTag: 54c6c456-d34e-4404-bce6-851765545c35

		annotation PBI_FormatHint = {"isGeneralNumber":true}

